<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>dashy</title>
  <style>
    :root {
      --green:  #33ff33; --amber: #ffb000; --red: #ff4444;
      --dim:    #4a5a4a; --bg:   #0a0a0a; --bg2: #0f0f0f;
      --border: #1a2a1a;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background:var(--bg); color:var(--green); font-family:'Courier New',monospace;
           font-size:14px; line-height:1.5; padding:16px; max-width:960px; margin:0 auto; }

    #header { text-align:center; border-bottom:1px solid var(--border); padding-bottom:8px; margin-bottom:16px; }
    #header .logo { font-size:1.3em; letter-spacing:4px; }
    #header .sub  { color:var(--dim); font-size:.85em; letter-spacing:2px; }
    .cursor::after { content:'█'; animation:blink 1s step-end infinite; }
    @keyframes blink { 50% { opacity:0; } }

    .panel { border:1px solid var(--border); padding:14px; background:var(--bg2); }
    .panel-title { color:var(--amber); border-bottom:1px solid var(--border);
                   margin-bottom:10px; padding-bottom:4px; font-size:.8em; letter-spacing:3px; text-transform:uppercase; }
    .panel-title::before { content:'── '; color:var(--dim); }
    .panel-title::after  { content:' ──'; color:var(--dim); }

    .grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }

    #clock-time { font-size:2em; letter-spacing:4px; text-align:center; padding:8px 0; }
    #clock-date { text-align:center; color:var(--dim); }
    #cal-output { white-space:pre; font-size:.92em; line-height:1.7; }
    .cal-today  { color:var(--amber); font-weight:bold; }

    .wx-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px 32px; }
    .wx-section-label { color:var(--dim); font-size:.75em; letter-spacing:2px; margin-bottom:5px; }
    .wx-row { display:flex; justify-content:space-between; padding:3px 0; border-bottom:1px solid #111; }
    .wx-label { color:var(--dim); } .wx-val { color:var(--green); }
    .prop-row { display:flex; justify-content:space-between; margin-top:10px; padding:6px 0;
                border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
    .prop-good { color:var(--green); } .prop-ok { color:var(--amber); } .prop-bad { color:var(--red); }
    .wx-source { color:var(--dim); font-size:.72em; margin-top:8px; }

    .bands-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:6px; margin-top:8px; }
    .band-card { border:1px solid var(--border); padding:7px 9px; }
    .band-name { color:var(--amber); font-size:.82em; letter-spacing:1px; margin-bottom:5px; }
    .band-bar-row { display:flex; align-items:center; gap:6px; margin-bottom:3px; font-size:.82em; }
    .band-bar-label { color:var(--dim); width:16px; flex-shrink:0; }
    .band-bar-track { flex:1; height:7px; background:#151515; border:1px solid #222; border-radius:2px; overflow:hidden; }
    .band-bar-fill { height:100%; border-radius:2px; }
    .fill-excellent { background:#33ff33; } .fill-good { background:#228822; }
    .fill-fair { background:#ffb000; }      .fill-poor { background:#331111; }
    .band-cond-text { width:62px; font-size:.85em; }
    .cond-excellent { color:#33ff33; } .cond-good { color:#228822; }
    .cond-fair { color:var(--amber); } .cond-poor { color:#553333; }

    /* Band plan table */
    .bp-table { width:100%; border-collapse:collapse; font-size:.85em; }
    .bp-table th { color:var(--amber); text-align:left; padding:4px 8px;
                   border-bottom:1px solid var(--border); font-weight:normal; letter-spacing:1px; }
    .bp-table td { padding:4px 8px; border-bottom:1px solid #111; }
    .bp-table tr:last-child td { border-bottom:none; }
    .bp-band   { color:var(--amber); font-weight:bold; white-space:nowrap; }
    .bp-range  { color:var(--dim); white-space:nowrap; font-size:.82em; }
    .bp-modes  { color:var(--green); white-space:nowrap; }
    .bp-calling { color:#96ffff; font-size:.82em; }
    .bp-notes  { color:var(--dim); font-size:.78em; }
    .bp-cb td  { border-top:1px solid var(--border); color:#ffaa44; }
    .bp-cb .bp-band { color:#ffaa44; }

    /* Ruby tip */
    .tip-title { color:var(--amber); margin-bottom:6px; font-size:.95em; }
    .tip-code  { color:var(--green); background:#050f05; border:1px solid var(--border);
                 padding:8px 12px; font-family:'Courier New',monospace; margin-bottom:6px;
                 font-size:.9em; white-space:pre-wrap; word-break:break-all; }
    .tip-note  { color:var(--dim); font-size:.82em; }

    /* News */
    .news-item { padding:7px 0; border-bottom:1px solid var(--border); }
    .news-item:last-child { border-bottom:none; }
    .news-num  { color:var(--dim); margin-right:4px; }
    .news-title a { color:var(--green); text-decoration:none; }
    .news-title a:hover { color:var(--amber); }
    .news-meta { color:var(--dim); font-size:.78em; margin-top:2px; padding-left:24px; }

    #footer { text-align:center; color:var(--dim); font-size:.78em;
              margin-top:12px; border-top:1px solid var(--border); padding-top:8px; }
    #footer a { color:var(--dim); text-decoration:none; }
    #footer a:hover { color:var(--amber); }

    @media (max-width:700px) {
      .grid-3, .wx-grid, .bands-grid { grid-template-columns:1fr; }
    }
  </style>
</head>
<body>
  <div id="header">
    <div class="logo">DASHY <span class="cursor"></span></div>
    <div class="sub">SP2MAG // Mac Mini // <%= Time.now.year %></div>
  </div>
  <%= yield %>
  <div id="footer">
    cache 10min &nbsp;|&nbsp; <a href="/refresh">odśwież</a> &nbsp;|&nbsp;
    <a href="/?format=text">curl view</a> &nbsp;|&nbsp; <span id="lr"></span>
  </div>
  <script>
    function tick() {
      const n=new Date(), p=x=>String(x).padStart(2,'0');
      const days=['Niedziela','Poniedziałek','Wtorek','Środa','Czwartek','Piątek','Sobota'];
      const mons=['Stycznia','Lutego','Marca','Kwietnia','Maja','Czerwca','Lipca','Sierpnia','Września','Października','Listopada','Grudnia'];
      const et=document.getElementById('clock-time'), ed=document.getElementById('clock-date');
      if(et) et.textContent=`${p(n.getHours())}:${p(n.getMinutes())}:${p(n.getSeconds())}`;
      if(ed) ed.textContent=`${days[n.getDay()]}, ${n.getDate()} ${mons[n.getMonth()]} ${n.getFullYear()}`;
    }
    setInterval(tick,1000); tick();
    document.addEventListener('DOMContentLoaded',()=>{
      const d=new Date().getDate(), cal=document.getElementById('cal-output');
      if(cal) cal.innerHTML=cal.textContent.replace(new RegExp(`\\b(${d})\\b`),`<span class="cal-today">$1</span>`);
    });
    setInterval(()=>fetch('/data.json').then(r=>r.json()).then(d=>{const e=document.getElementById('lr');if(e)e.textContent='refresh: '+d.fetched}).catch(()=>{}),600000);
  </script>
</body>
</html>
