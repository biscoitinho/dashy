<%
  wx   = @d[:space_wx] || {}
  prop = wx[:propagation] || {}
  flux = wx[:solar_flux]
  kp   = wx[:kp_index]
%>
<%= t_box_top('DASHY  ◆  SP2MAG') %><%= t_box_row(t_white(@d[:time]) + t_dim("  ") + t_amber(@d[:utc]) + t_dim("   #{@d[:date]}")) %><%= t_box_row(t_dim("wschod ") + t_amber(@d.dig(:sun, :sunrise) || '--:--') + t_dim("  zachod ") + t_amber(@d.dig(:sun, :sunset) || '--:--') + t_dim("  dzien ") + t_cyan(@d.dig(:sun, :day_length) || '--')) %><%= t_box_bot %>
<%= t_box_top('CALENDAR') %><%= t_cal_block(@d[:cal]) %><%= t_box_bot %>
<%= t_box_top('SPACE WEATHER  //  N0NBH / solar.w5mmw.net') %><%= t_two_col("Solar Flux  ", flux ? t_amber("#{flux} sfu") : t_dim('N/A'), "  Kp Index  ", kp ? t_amber(kp.to_s) : t_dim('N/A')) %><%= t_box_row(t_dim("            ") + t_bar(flux, 300) + t_dim("  flux") + "          " + t_bar(kp, 9) + t_dim("  kp")) %><%= t_box_sep %><%= t_two_col("Sunspots    ", t_white((wx[:sunspots] || 'N/A').to_s), "  A-Index   ", t_white((wx[:a_index] || 'N/A').to_s)) %><%= t_two_col("X-Ray       ", t_white((wx[:x_ray] || 'N/A').to_s), "  Storm     ", t_white((wx[:geomag] || 'N/A').to_s)) %><%= t_two_col("Solar wind  ", wx[:solar_wind] ? t_amber("#{wx[:solar_wind].to_i} km/s") : t_dim('N/A'), "  Bz field  ", wx[:mag_field] ? t_white("#{wx[:mag_field]} nT") : t_dim('N/A')) %><%= t_two_col("Aurora      ", wx[:aurora] ? t_green("#{wx[:aurora]}/100") : t_dim('N/A'), "  Lat       ", wx[:aurora_lat] ? t_cyan("#{wx[:aurora_lat]}°") : t_dim('N/A')) %><%= t_box_sep %><%= t_box_row(t_dim("Propagacja  ") + t_prop(prop[:label] || 'N/A', prop[:level] || 0)) %><%= t_bands_block(wx[:bands] || {}) %><%= t_box_row(t_dim("#{wx[:updated] || '-'}  ·  #{wx[:source] || 'N0NBH'}")) %><%= t_box_bot %>
<%= t_box_top('BAND PLAN  //  IARU R1 + CB  (SP2MAG)') %><%= t_box_row(t_dim("#{"BAND".ljust(6)} #{"MHz RANGE".ljust(18)} #{"MODES".ljust(12)} CALLING FREQ")) %><%= t_box_sep %><%= t_bandplan_block(@d[:band_plan]) %><%= t_box_bot %>
<%= t_box_top('AIR QUALITY  //  GIOS') %><%= t_air_block(@d[:air]) %><%= t_box_bot %>
<%= t_box_top('RUBY TIP OF THE DAY') %><%= t_tip_block(@d[:ruby_tip]) %><%= t_box_bot %>
<%= t_box_top('DX CLUSTER  //  dxsummit.fi') %><%= t_dx_block(@d[:dx_spots] || []) %><%= t_box_bot %>
<%= t_box_top('SOTA / POTA  //  aktywne stacje') %><%= t_sota_pota_block(@d[:sota_pota] || {}) %><%= t_box_bot %>
<%= t_box_top('RUBY WEEKLY') %><%= t_news_block(@d[:ruby_news]) %><%= t_box_bot %>
<%= t_dim("  curl localhost:4567                         # z kolorami
") %><%= t_dim("  curl 'localhost:4567/?plain=1'              # bez kolorow
") %><%= t_dim("  curl 'localhost:4567/?width=\$(tput cols)'   # szerokosc
") %>
